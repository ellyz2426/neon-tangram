{
  "name": "@iwsdk/xr-input",
  "version": "0.4.2",
  "description": "WebXR input system with controller and hand tracking support, visual adapters, and input profiles for Three.js applications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/immersive-web-sdk.git"
  },
  "keywords": [
    "webxr",
    "input",
    "controller",
    "hand-tracking",
    "three.js"
  ],
  "author": "Felix Zhang <fe1ix@meta.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/facebook/immersive-web-sdk/issues"
  },
  "homepage": "https://github.com/facebook/immersive-web-sdk#readme",
  "dependencies": {
    "@pmndrs/pointer-events": "^6.6.22",
    "@preact/signals-core": "^1.11.0"
  },
  "peerDependencies": {
    "three": ">=0.160.0"
  },
  "engines": {
    "node": ">=20.19.0 <21.0.0-0 || >=22.12.0 <23.0.0-0 || >=24.0.0"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  },
  "scripts": {
    "prebuild": "node -p \"'export const VERSION = ' + JSON.stringify(require('./package.json').version) + ';'\" > src/version.ts && node scripts/generate-input-profiles.js",
    "build": "rollup -c",
    "format": "prettier --write ./src/**/*",
    "test": "vitest run"
  }
}