{
  "name": "@iwsdk/core",
  "version": "0.4.2",
  "description": "Javascript WebXR Runtime for Emulation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "dist/index.js",
    "dist/asset/**",
    "dist/audio/**",
    "dist/camera/**",
    "dist/depth/**",
    "dist/ecs/**",
    "dist/environment/**",
    "dist/environment-raycast/**",
    "dist/grab/**",
    "dist/init/**",
    "dist/input/**",
    "dist/layers/**",
    "dist/level/**",
    "dist/locomotion/**",
    "dist/mcp/**",
    "dist/runtime/**",
    "dist/scene-understanding/**",
    "dist/transform/**",
    "dist/ui/**",
    "dist/vendor/**",
    "dist/visibility/**"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/immersive-web-sdk.git"
  },
  "keywords": [],
  "author": "Felix Zhang <fe1ix@meta.com>",
  "contributor": "Jianmin Zheng <zjm@meta.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/facebook/immersive-web-sdk/issues"
  },
  "homepage": "https://github.com/facebook/immersive-web-sdk#readme",
  "dependencies": {
    "@babylonjs/havok": "^1.3.10",
    "@pmndrs/handle": "^6.6.16",
    "@pmndrs/pointer-events": "^6.6.22",
    "@pmndrs/uikit": "^1.0.62",
    "@pmndrs/uikitml": "^0.1.12",
    "@preact/signals-core": "^1.11.0",
    "elics": "^3.4.1",
    "three": "*",
    "three-mesh-bvh": "^0.9.1",
    "@iwsdk/xr-input": "0.4.2",
    "@iwsdk/glxf": "0.4.2",
    "@iwsdk/locomotor": "0.4.2"
  },
  "engines": {
    "node": ">=20.19.0 <21.0.0-0 || >=22.12.0 <23.0.0-0 || >=24.0.0"
  },
  "devDependencies": {
    "vitest": "^4.0.0",
    "@vitest/coverage-v8": "^4.0.0"
  },
  "scripts": {
    "prebuild": "node -p \"'export const VERSION = ' + JSON.stringify(require('./package.json').version) + ';'\" > src/version.ts",
    "build": "rollup -c",
    "doc": "typedoc",
    "format": "prettier --write ./src/**/*",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  }
}